{% assign repo_parts = include.item.repo | split: '/' %}
{% assign owner = repo_parts[0] %}
{% assign repo_name = repo_parts[1] %}
{% if include.item.url %}
  {% assign repo_href = include.item.url %}
{% else %}
  {% assign repo_href = include.item.repo | prepend: 'https://github.com/' %}
{% endif %}

<a
  href="{{ repo_href }}"
  class="opensource-card"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="{{ include.item.name | default: include.item.repo }}"
  data-repo="{{ include.item.repo }}"
>
  <img
    class="opensource-avatar"
    src="https://github.com/{{ owner }}.png?size=80"
    alt=""
    width="40"
    height="40"
    loading="lazy"
  >
  <div class="opensource-meta">
    <div class="opensource-title">
      <span class="opensource-owner">{{ owner }}</span>/<span class="opensource-name">{{ repo_name }}</span>
    </div>
    {% if include.item.description %}
      <p class="opensource-description">{{ include.item.description }}</p>
    {% endif %}
    <div class="opensource-stats">
      {% if include.item.language %}
        <span class="opensource-language">
          <span class="opensource-language-dot" aria-hidden="true"></span>
          {{ include.item.language }}
        </span>
      {% endif %}
      {% if include.item.stars %}
        <span class="opensource-stat" title="Stars">
          <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
            <path fill="currentColor" d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"></path>
          </svg>
          <span class="opensource-stars" data-stat="stars">{{ include.item.stars }}</span>
        </span>
      {% endif %}
      {% if include.item.forks %}
        <span class="opensource-stat" title="Forks">
          <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
            <path fill="currentColor" d="M5 5.372v.878c0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75v-.878a2.25 2.25 0 1 1 1.5 0v.878a2.25 2.25 0 0 1-2.25 2.25h-1.5v2.128a2.251 2.251 0 1 1-1.5 0V8.25h-1.5A2.25 2.25 0 0 1 3.5 6v-.878a2.25 2.25 0 1 1 1.5 0ZM5 3.25a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Zm6.75.75a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm-3 8.75a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Z"></path>
          </svg>
          <span class="opensource-forks" data-stat="forks">{{ include.item.forks }}</span>
        </span>
      {% endif %}
    </div>
  </div>
</a>
